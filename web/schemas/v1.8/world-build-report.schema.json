{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traditionalboardgames.example/schemas/v1.8/world-build-report.schema.json",
  "title": "Traditional Board Games deterministic world build report",
  "description": "Closed report for a reproducible World Factory inspection, build, or verification. buildId is SHA-256 over RFC 8785 canonical JSON of the identity object only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema",
    "game",
    "worldId",
    "command",
    "purpose",
    "buildId",
    "identity",
    "outputs",
    "probes",
    "budgets",
    "semanticFixture",
    "screenshots",
    "gates",
    "gateSummary",
    "review",
    "packaging",
    "blockers"
  ],
  "properties": {
    "format": {
      "const": "tbg-world-build-report"
    },
    "schema": {
      "const": 1
    },
    "game": {
      "$ref": "#/$defs/game"
    },
    "worldId": {
      "$ref": "#/$defs/id"
    },
    "command": {
      "enum": [
        "inspect",
        "build",
        "verify"
      ]
    },
    "purpose": {
      "enum": [
        "internal-review",
        "package-candidate"
      ]
    },
    "buildId": {
      "$ref": "#/$defs/sha256"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "probes": {
      "type": "array",
      "maxItems": 4096,
      "items": {
        "$ref": "#/$defs/probe"
      }
    },
    "budgets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/budget"
      }
    },
    "semanticFixture": {
      "$ref": "#/$defs/semanticFixture"
    },
    "screenshots": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/screenshot"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "gateSummary": {
      "$ref": "#/$defs/gateSummary"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "packaging": {
      "$ref": "#/$defs/packaging"
    },
    "blockers": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/blocker"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "purpose"
        ],
        "properties": {
          "purpose": {
            "const": "package-candidate"
          }
        }
      },
      "then": {
        "properties": {
          "gateSummary": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          },
          "review": {
            "properties": {
              "status": {
                "const": "approved"
              },
              "culturalReviewed": {
                "const": true
              },
              "rightsReviewed": {
                "const": true
              },
              "approvedForPackaging": {
                "const": true
              }
            }
          },
          "packaging": {
            "properties": {
              "status": {
                "enum": [
                  "ready",
                  "packaged"
                ]
              }
            }
          },
          "gates": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/gate"
                },
                {
                  "properties": {
                    "status": {
                      "const": "pass"
                    }
                  }
                }
              ]
            }
          },
          "blockers": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "game": {
      "enum": [
        "ah",
        "am",
        "cb",
        "sma"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[?#\\\\])[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
      "maxLength": 256
    },
    "schemaId": {
      "type": "string",
      "pattern": "^https://traditionalboardgames\\.example/schemas/v1\\.8/[a-z0-9-]+\\.schema\\.json$",
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+){0,3}(?:-[A-Za-z0-9.-]{1,32})?$",
      "maxLength": 48
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "normalizedInputs",
        "sourceAssets",
        "schemas",
        "tools",
        "environment",
        "budgetPolicy"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256-rfc8785-v1"
        },
        "normalizedInputs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identityInput"
          }
        },
        "sourceAssets": {
          "type": "array",
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/digest"
          }
        },
        "schemas": {
          "type": "array",
          "minItems": 3,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/schemaPin"
          }
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/toolPin"
          }
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "budgetPolicy": {
          "$ref": "#/$defs/policyPin"
        }
      }
    },
    "identityInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "world-v2",
            "provenance",
            "asset-inventory",
            "content-catalog",
            "translation-queue",
            "renderer-compatibility"
          ]
        },
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "schemaPin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "schemaId",
        "version",
        "sha256"
      ],
      "properties": {
        "name": {
          "enum": [
            "world-v2",
            "provenance",
            "asset-inventory",
            "world-build-report"
          ]
        },
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "schemaId": {
          "$ref": "#/$defs/schemaId"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "toolPin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "sha256"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "policyPin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "version",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "architecture",
        "nodeVersion"
      ],
      "properties": {
        "platform": {
          "enum": [
            "darwin",
            "linux",
            "win32"
          ]
        },
        "architecture": {
          "enum": [
            "arm64",
            "x64"
          ]
        },
        "nodeVersion": {
          "$ref": "#/$defs/version"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "mediaType",
        "bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "world-manifest",
            "provenance",
            "asset-inventory",
            "content-catalog",
            "language-manifest",
            "optimized-asset",
            "semantic-fixture",
            "screenshot",
            "budget-report"
          ]
        },
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "mediaType": {
          "enum": [
            "application/json",
            "image/avif",
            "image/jpeg",
            "image/png",
            "image/webp",
            "audio/mpeg",
            "audio/ogg",
            "audio/wav",
            "audio/webm"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "status",
        "facts"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "kind": {
          "enum": [
            "json",
            "image",
            "audio"
          ]
        },
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "facts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/fact"
          }
        }
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "unit"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "value": {
          "type": "number",
          "minimum": -1000000000,
          "maximum": 1000000000
        },
        "unit": {
          "enum": [
            "bytes",
            "pixels",
            "milliseconds",
            "hertz",
            "channels",
            "decibels",
            "count"
          ]
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "path",
        "actualBytes",
        "limitBytes",
        "status"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/name"
        },
        "path": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/safePath"
            }
          ]
        },
        "actualBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "limitBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    },
    "semanticFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "rulesetId",
        "rulesetVersion",
        "status"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rulesetId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,15}\\.[a-z][a-z0-9-]{0,63}$"
        },
        "rulesetVersion": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    },
    "screenshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "viewport",
        "consoleErrors",
        "status"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "viewport": {
          "$ref": "#/$defs/viewport"
        },
        "consoleErrors": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "pending-review"
          ]
        }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "deviceScaleFactor"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 240,
          "maximum": 7680
        },
        "height": {
          "type": "integer",
          "minimum": 240,
          "maximum": 7680
        },
        "deviceScaleFactor": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 4
        }
      }
    },
    "gateSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "passed",
        "failed",
        "blocked"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "fail",
            "blocked"
          ]
        },
        "passed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "failed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "blocked": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "evidence"
      ],
      "properties": {
        "id": {
          "enum": [
            "schema",
            "provenance",
            "rights",
            "compatibility",
            "content",
            "assets",
            "semantic",
            "screenshots",
            "budgets",
            "reproducibility"
          ]
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "blocked"
          ]
        },
        "evidence": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/safePath"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "culturalReviewed",
        "rightsReviewed",
        "approvedForPackaging"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "culturalReviewed": {
          "type": "boolean"
        },
        "rightsReviewed": {
          "type": "boolean"
        },
        "approvedForPackaging": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "approvedForPackaging"
            ],
            "properties": {
              "approvedForPackaging": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "status": {
                "const": "approved"
              },
              "culturalReviewed": {
                "const": true
              },
              "rightsReviewed": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "packaging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "artifactPath",
        "artifactSha256"
      ],
      "properties": {
        "status": {
          "enum": [
            "not-requested",
            "blocked",
            "ready",
            "packaged"
          ]
        },
        "artifactPath": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/safePath"
            }
          ]
        },
        "artifactSha256": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sha256"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "packaged"
              }
            }
          },
          "then": {
            "properties": {
              "artifactPath": {
                "$ref": "#/$defs/safePath"
              },
              "artifactSha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          },
          "else": {
            "properties": {
              "artifactPath": {
                "type": "null"
              },
              "artifactSha256": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "gate",
        "path",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
        },
        "gate": {
          "$ref": "#/$defs/name"
        },
        "path": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/safePath"
            }
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    }
  }
}
