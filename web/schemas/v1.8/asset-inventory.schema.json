{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traditionalboardgames.example/schemas/v1.8/asset-inventory.schema.json",
  "title": "Traditional Board Games asset inventory",
  "description": "Bounded, hash-addressed inventory for core and optional install packs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "game",
    "root",
    "packs",
    "assets",
    "totals"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "game": {
      "$ref": "#/$defs/game"
    },
    "root": {
      "const": "web"
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/pack"
      }
    },
    "assets": {
      "type": "array",
      "maxItems": 8192,
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "totals": {
      "$ref": "#/$defs/totals"
    }
  },
  "$defs": {
    "game": {
      "enum": [
        "ah",
        "am",
        "cb",
        "sma"
      ]
    },
    "shortId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "packId": {
      "type": "string",
      "pattern": "^(?:core|(?:world|language|campaign|cinematic):[a-z][a-z0-9-]{0,63})$",
      "maxLength": 80
    },
    "assetPath": {
      "type": "string",
      "pattern": "^assets/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
      "maxLength": 256
    },
    "webPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[?#\\\\])[A-Za-z0-9][A-Za-z0-9._/-]{0,254}$",
      "maxLength": 256
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "manifestPath",
        "manifestSha256",
        "assetCount",
        "bytes",
        "requiredAtStartup"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/packId"
        },
        "kind": {
          "enum": [
            "core",
            "world",
            "language",
            "campaign",
            "cinematic"
          ]
        },
        "manifestPath": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/webPath"
            }
          ]
        },
        "manifestSha256": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sha256"
            }
          ]
        },
        "assetCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8192
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "requiredAtStartup": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "core"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "const": "core"
              },
              "manifestPath": {
                "type": "null"
              },
              "manifestSha256": {
                "type": "null"
              },
              "requiredAtStartup": {
                "const": true
              }
            }
          },
          "else": {
            "properties": {
              "manifestPath": {
                "$ref": "#/$defs/webPath"
              },
              "manifestSha256": {
                "$ref": "#/$defs/sha256"
              },
              "requiredAtStartup": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "world"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^world:[a-z][a-z0-9-]{0,63}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "language"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^language:[a-z][a-z0-9-]{0,63}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "campaign"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^campaign:[a-z][a-z0-9-]{0,63}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "cinematic"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^cinematic:[a-z][a-z0-9-]{0,63}$"
              }
            }
          }
        }
      ]
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "packId",
        "role",
        "mediaType",
        "bytes",
        "sha256",
        "preload"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/assetPath"
        },
        "packId": {
          "$ref": "#/$defs/packId"
        },
        "role": {
          "enum": [
            "brand",
            "ui",
            "font",
            "board-texture",
            "piece-texture",
            "environment",
            "poster",
            "music",
            "ambience",
            "voice",
            "cinematic",
            "campaign",
            "other"
          ]
        },
        "mediaType": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9!#$&^_.+-]{0,63}/[a-z0-9][a-z0-9!#$&^_.+-]{0,63}$",
          "maxLength": 129
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1073741824
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "preload": {
          "type": "boolean"
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetCount",
        "bytes",
        "coreBytes",
        "optionalBytes"
      ],
      "properties": {
        "assetCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8192
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967296
        },
        "coreBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "optionalBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967296
        }
      }
    }
  }
}
