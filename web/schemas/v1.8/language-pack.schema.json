{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traditionalboardgames.example/schemas/v1.8/language-pack.schema.json",
  "title": "Traditional Board Games language index and component pack",
  "description": "Validates either the trusted bundled index or one independently installable text/voice component manifest.",
  "oneOf": [
    {
      "$ref": "#/$defs/index"
    },
    {
      "$ref": "#/$defs/pack"
    }
  ],
  "$defs": {
    "game": {
      "enum": [
        "ah",
        "am",
        "cb",
        "sma"
      ]
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(?:-[A-Z][a-z]{3})?(?:-(?:[A-Z]{2}|[0-9]{3}))?$",
      "maxLength": 24
    },
    "version": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,5})\\.(?:0|[1-9][0-9]{0,5})\\.(?:0|[1-9][0-9]{0,5})(?:-[0-9A-Za-z.-]{1,48})?$",
      "maxLength": 72
    },
    "contentId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9][a-z0-9_-]*){2,}$",
      "maxLength": 160
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "packPath": {
      "type": "string",
      "pattern": "^packs/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[?#\\\\])(?:ah|am|cb|sma)/[A-Za-z0-9][A-Za-z0-9._/-]{0,242}$",
      "maxLength": 256
    },
    "manifestPath": {
      "type": "string",
      "pattern": "^packs/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[?#\\\\])(?:ah|am|cb|sma)/[A-Za-z0-9][A-Za-z0-9._/-]{0,228}\\.manifest\\.json$",
      "maxLength": 256
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "schema",
        "game",
        "defaultLanguage",
        "coreLanguages",
        "packs"
      ],
      "properties": {
        "format": {
          "const": "tbg-language-index"
        },
        "schema": {
          "const": 1
        },
        "game": {
          "$ref": "#/$defs/game"
        },
        "defaultLanguage": {
          "const": "en"
        },
        "coreLanguages": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "contains": {
            "const": "en"
          },
          "items": {
            "$ref": "#/$defs/language"
          }
        },
        "packs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/indexEntry"
          }
        }
      }
    },
    "indexEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "component",
        "version",
        "contentVersion",
        "manifestPath",
        "manifestBytes",
        "manifestSha256",
        "packBytes",
        "packSha256"
      ],
      "properties": {
        "language": {
          "$ref": "#/$defs/language"
        },
        "component": {
          "enum": [
            "text",
            "voice"
          ]
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "contentVersion": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        },
        "manifestPath": {
          "$ref": "#/$defs/manifestPath"
        },
        "manifestBytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 4194304
        },
        "manifestSha256": {
          "$ref": "#/$defs/sha256"
        },
        "packBytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 268435456
        },
        "packSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "schema",
        "game",
        "language",
        "version",
        "contentVersion",
        "component",
        "fallbackLanguage",
        "bytes",
        "sha256",
        "files"
      ],
      "properties": {
        "format": {
          "const": "tbg-language-pack"
        },
        "schema": {
          "const": 1
        },
        "game": {
          "$ref": "#/$defs/game"
        },
        "language": {
          "$ref": "#/$defs/language"
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "contentVersion": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        },
        "component": {
          "enum": [
            "text",
            "voice"
          ]
        },
        "fallbackLanguage": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/language"
            }
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 268435456
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/file"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "component": {
                "const": "voice"
              }
            }
          },
          "then": {
            "properties": {
              "fallbackLanguage": {
                "type": "null"
              }
            }
          },
          "else": {
            "if": {
              "properties": {
                "language": {
                  "const": "en"
                }
              }
            },
            "then": {
              "properties": {
                "fallbackLanguage": {
                  "type": "null"
                }
              }
            },
            "else": {
              "properties": {
                "fallbackLanguage": {
                  "const": "en"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "component": {
                "const": "text"
              }
            }
          },
          "then": {
            "properties": {
              "files": {
                "items": {
                  "$ref": "#/$defs/textFile"
                }
              }
            }
          },
          "else": {
            "properties": {
              "files": {
                "items": {
                  "$ref": "#/$defs/voiceFile"
                }
              }
            }
          }
        }
      ]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "mediaType",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/packPath"
        },
        "role": {
          "enum": [
            "ui",
            "world",
            "campaign",
            "puzzle",
            "recap",
            "achievement",
            "share",
            "provenance",
            "glossary",
            "tutorial",
            "voice-manifest",
            "voice"
          ]
        },
        "mediaType": {
          "enum": [
            "application/json",
            "audio/mpeg",
            "audio/ogg",
            "audio/wav",
            "audio/webm"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 67108864
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "contentId": {
          "$ref": "#/$defs/contentId"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "voiceId": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,79}$",
          "maxLength": 80
        }
      }
    },
    "textFile": {
      "allOf": [
        {
          "$ref": "#/$defs/file"
        },
        {
          "properties": {
            "role": {
              "enum": [
                "ui",
                "world",
                "campaign",
                "puzzle",
                "recap",
                "achievement",
                "share",
                "provenance",
                "glossary",
                "tutorial"
              ]
            },
            "mediaType": {
              "const": "application/json"
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "durationMs"
                ]
              },
              {
                "required": [
                  "voiceId"
                ]
              }
            ]
          }
        }
      ]
    },
    "voiceFile": {
      "allOf": [
        {
          "$ref": "#/$defs/file"
        },
        {
          "properties": {
            "role": {
              "enum": [
                "voice-manifest",
                "voice"
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "role": {
                    "const": "voice-manifest"
                  }
                }
              },
              "then": {
                "properties": {
                  "mediaType": {
                    "const": "application/json"
                  }
                },
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "durationMs"
                      ]
                    },
                    {
                      "required": [
                        "voiceId"
                      ]
                    },
                    {
                      "required": [
                        "contentId"
                      ]
                    }
                  ]
                }
              },
              "else": {
                "required": [
                  "contentId",
                  "durationMs",
                  "voiceId"
                ],
                "properties": {
                  "mediaType": {
                    "enum": [
                      "audio/mpeg",
                      "audio/ogg",
                      "audio/wav",
                      "audio/webm"
                    ]
                  }
                }
              }
            }
          ]
        }
      ]
    }
  }
}
